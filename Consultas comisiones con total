    reporte.alumno,
    reporte.hrs,
    reporte.fecha_pago,
    reporte.cobrado,
    reporte.comisiongenerada,
    reporte.comisionpagada,
    reporte.a_pagar
FROM
(
    SELECT
        base.idalumno,
        base.alumno,
        base.hrs,
        base.fecha_pago,
        base.cobrado,
        base.comisiongenerada,
        base.comisionpagada,
        ROUND(base.comisiongenerada - base.comisionpagada, 2) AS a_pagar,
        1 AS orden
    FROM base

    UNION ALL

    SELECT
        NULL AS idalumno,
        'TOTAL' AS alumno,
        SUM(base.hrs) AS hrs,
        NULL AS fecha_pago,
        ROUND(SUM(base.cobrado), 2) AS cobrado,
        ROUND(SUM(base.comisiongenerada), 2) AS comisiongenerada,
        ROUND(SUM(base.comisionpagada), 2) AS comisionpagada,
        ROUND(SUM(base.comisiongenerada - base.comisionpagada), 2) AS a_pagar,
        2 AS orden
    FROM base
) AS reporte
ORDER BY
    reporte.orden,
    reporte.fecha_pago,
    reporte.alumno;