WITH base AS (
    SELECT
        p.idusuarios AS idalumno,

        CONCAT(
            COALESCE(alumno_central.nombre, ''),
            ' ',
            COALESCE(alumno_central.paterno, ''),
            ' ',
            COALESCE(alumno_central.materno, '')
        ) AS alumno,

        COALESCE(horarios.cantidadhorarios, 0) AS hrs,

        DATE(np.fecha) AS fecha_pago,

        np.idnotapago,
        np.folio,
        npd.idnotapago_descripcion,
        p.idpago,
        p.idservicio,

        COALESCE(p.monto, 0) AS monto_pago,

        COALESCE(descuentos.descuento_normal, 0) AS descuento_normal,
        COALESCE(descuentos.descuento_membresia, 0) AS descuento_membresia,
        COALESCE(descuentos.descuento_total, 0) AS descuento_total,

        ROUND(
            COALESCE(p.monto, 0)
            - COALESCE(descuentos.descuento_total, 0),
            2
        ) AS cobrado,

        ROUND(
            CASE
                WHEN COALESCE(uc.tipopago, tc.tipocomision) = 0 THEN
                    COALESCE(p.monto, 0)
                    * COALESCE(uc.monto, tc.monto, 0) / 100

                WHEN COALESCE(uc.tipopago, tc.tipocomision) = 1 THEN
                    COALESCE(uc.monto, tc.monto, 0)
                    * COALESCE(horarios.cantidadhorarios, 0)
                    / NULLIF(COALESCE(participantes.cantidadparticipantes, 0), 0)

                WHEN COALESCE(uc.tipopago, tc.tipocomision) = 2 THEN
                    COALESCE(horarios.cantidadhorarios, 0)
                    * COALESCE(uc.monto, tc.monto, 0)

                ELSE 0
            END,
            2
        ) AS comisiongenerada,

        COALESCE(pc.comisionpagada, 0) AS comisionpagada,

        COALESCE(uc.tipopago, tc.tipocomision) AS tipo_comision,
        COALESCE(uc.monto, tc.monto, 0) AS cantidad_comision,
        COALESCE(participantes.cantidadparticipantes, 0) AS cantidadparticipantes

    FROM notapago_descripcion npd

    INNER JOIN pagos p
        ON npd.idpago = p.idpago

    INNER JOIN notapago np
        ON np.idnotapago = npd.idnotapago

    LEFT JOIN (
        SELECT
            idnotapago,
            idnotapago_descripcion,

            SUM(
                CASE
                    WHEN tipo_descuento IN (1,3,4)
                    THEN COALESCE(monto_descontado, 0)
                    ELSE 0
                END
            ) AS descuento_normal,

            SUM(
                CASE
                    WHEN tipo_descuento IN (2)
                    THEN COALESCE(monto_descontado, 0)
                    ELSE 0
                END
            ) AS descuento_membresia,

            SUM(COALESCE(monto_descontado, 0)) AS descuento_total

        FROM notapago_descuento_aplicado
        WHERE tipo_descuento IN (1,2,3,4)
        GROUP BY
            idnotapago,
            idnotapago_descripcion
    ) descuentos
        ON descuentos.idnotapago = np.idnotapago
        AND descuentos.idnotapago_descripcion = npd.idnotapago_descripcion

    INNER JOIN servicios s
        ON s.idservicio = p.idservicio

    INNER JOIN bdcentralwon.usuarios_central alumno_central
        ON alumno_central.idusuarios = p.idusuarios

    INNER JOIN usuarios_servicios coach_us
        ON coach_us.idservicio = p.idservicio
        AND coach_us.cancelacion = 0
        AND coach_us.idusuarios = 2044

    INNER JOIN usuarios ucoach
        ON ucoach.idusuarios = coach_us.idusuarios
        AND ucoach.id_tipo_coach > 0

    LEFT JOIN usuarioscoachs uc
        ON uc.idusuarios_servicios = coach_us.idusuarios_servicios

    LEFT JOIN bdcentralwon.usuarios_central coach_central
        ON coach_central.idusuarios = coach_us.idusuarios

    LEFT JOIN tipocoach tc
        ON coach_central.idtipocoach = tc.idtipocoach

    LEFT JOIN (
        SELECT
            idservicio,
            COUNT(*) AS cantidadhorarios
        FROM horariosservicio
        GROUP BY idservicio
    ) horarios
        ON horarios.idservicio = p.idservicio

    LEFT JOIN (
        SELECT
            usv.idservicio,
            COUNT(DISTINCT usv.idusuarios) AS cantidadparticipantes
        FROM usuarios_servicios usv
        LEFT JOIN usuarios u
            ON u.idusuarios = usv.idusuarios
        WHERE
            usv.cancelacion = 0
            AND (
                u.id_tipo_coach IS NULL
                OR u.id_tipo_coach = 0
            )
        GROUP BY usv.idservicio
    ) participantes
        ON participantes.idservicio = p.idservicio

    LEFT JOIN (
        SELECT
            idpago,
            idusuarios AS idcoach,
            SUM(COALESCE(monto, 0)) AS comisionpagada
        FROM pagoscoach
        WHERE
            idusuarios = 2044
            AND (
                pagado = 1
                OR estatus = 2
            )
        GROUP BY
            idpago,
            idusuarios
    ) pc
        ON pc.idpago = p.idpago
        AND pc.idcoach = coach_us.idusuarios

